{
	"name": "fuzzy",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*", "apps/*"],
	"engines": { "bun": ">=1.1.0" },
	"scripts": {
		"format": "biome format --write . && prettier --plugin prettier-plugin-svelte --write \"**/*.svelte\"",
		"lint": "biome lint --write .",
		"check": "biome check --write . && prettier --plugin prettier-plugin-svelte --write \"**/*.svelte\"",
		"check:ci": "biome ci . && prettier --plugin prettier-plugin-svelte --check \"**/*.svelte\"",
		"test": "bun test",
		"typecheck:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
		"typecheck:extension": "tsc --noEmit -p apps/extension/tsconfig.json",
		"typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
		"typecheck": "bun run typecheck:shared && bun run typecheck:extension && bun run typecheck:tests",
		"build:extension": "bun run --cwd apps/extension build",
		"build": "bun run check && bun run typecheck && bun run test && bun run build:extension",
		"verify": "bun run check:ci && bun run typecheck && bun run test && bun run build:extension && cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace --all-targets",
		"fmt:rust": "cargo fmt --all",
		"lint:rust": "cargo clippy --workspace --all-targets -- -D warnings"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"linkedom": "^0.18.12",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte": "5.55.6",
		"typescript": "^5.6.2"
	}
}
