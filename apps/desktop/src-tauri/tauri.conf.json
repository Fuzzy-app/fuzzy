{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Fuzzy Desktop",
	"version": "0.1.0",
	"identifier": "com.fuzzy.desktop",
	"build": {
		"beforeDevCommand": "bun run dev:tauri",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build:tauri",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Fuzzy 初期セットアップ",
				"width": 1080,
				"height": 760,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"resources": {
			"../../extension/.output/chrome-mv3/": "extension/chrome-mv3/"
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
